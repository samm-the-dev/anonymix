{
  "name": "anonymix",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "lint": "eslint .",
    "format": "prettier --write \"./**/*.{ts,tsx,json,css,md}\"",
    "format:check": "prettier --check \"./**/*.{ts,tsx,json,css,md}\"",
    "test": "vitest",
    "test:run": "vitest run",
    "test:e2e": "playwright test",
    "test:prototype": "playwright test --project=prototype-mobile-14",
    "test:prototype:all": "playwright test --grep prototype",
    "test:prototype:headed": "playwright test --project=prototype-mobile-14 --headed",
    "db:push": "supabase db push",
    "db:advisors": "bash scripts/db-advisors.sh",
    "db:gen-types": "supabase gen types typescript --project-id mryuusvhdadbjpupzpol > src/lib/database.types.ts",
    "gen:icons": "node scripts/gen-icons.mjs",
    "gen:og": "node scripts/gen-og.mjs"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@playwright/test": "^1.58.2",
    "@tailwindcss/vite": "^4.2.2",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^25.5.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.2.0",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.26",
    "globals": "^17.4.0",
    "jsdom": "^29.0.1",
    "prettier": "^3.8.1",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "serve": "^14.2.6",
    "supabase": "^2.84.4",
    "tailwindcss": "^4.2.2",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.57.2",
    "vite": "^7.3.1",
    "vite-plugin-mkcert": "^1.17.10",
    "vite-plugin-pwa": "^1.2.0",
    "vitest": "^4.1.2"
  },
  "dependencies": {
    "@radix-ui/react-alert-dialog": "^1.1.15",
    "@radix-ui/react-collapsible": "^1.1.12",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-popover": "^1.1.15",
    "@supabase/supabase-js": "^2.100.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^1.7.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-router-dom": "^7.13.2",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0"
  }
